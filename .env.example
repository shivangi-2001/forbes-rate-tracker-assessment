# ─────────────────────────────────────────────────────────────────────────────
# Rate Tracker — environment variables
# Copy this file to .env and fill in real values before running docker-compose.
# The application WILL NOT START if SECRET_KEY, DATABASE_URL, or INGEST_API_KEY
# are missing — see backend/scripts/entrypoint.sh for the fail-fast checks.
# ─────────────────────────────────────────────────────────────────────────────

# Django secret key — generate with:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=va^iw2pvsrb1te2sc%jv7-i)p0k8qc^)an1(@^li4i&x6j+=nn

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://rates:rates@db:5432/rates_db

# Redis connection string (used for Celery broker + Django cache)
REDIS_URL=redis://redis:6379/0

# Static bearer token for POST /rates/ingest — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=Y-AeML8HAKHEEww5ECbdPvaRyTmiRJEHl3wLzK3Zax4

# CORS: comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
